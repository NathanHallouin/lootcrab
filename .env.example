# Discord Bot Configuration
# Copy this file to .env and fill in the values

# Discord Token - Required
# Get it from https://discord.com/developers/applications
DISCORD_TOKEN=

# Log level (optional)
# Values: trace, debug, info, warn, error
RUST_LOG=info

# Development server ID (optional)
# Register commands only on this server during development
DEV_GUILD_ID=

# === Notes ===
# Free games notifications are configured via Discord with /freegames-setup
# Data is saved in data/config.json
